# Copy to .env.local for local development, and set the same names as
# Environment Variables in the Vercel project settings for production.

# Any standard PostgreSQL connection string works here (Vercel Postgres /
# Neon integration sets POSTGRES_URL automatically; Supabase, Railway, etc.
# use DATABASE_URL by convention — either name is read by this app).
POSTGRES_URL=

# Provided automatically when you add Vercel Blob to this project
# (Storage tab -> Create Database -> Blob -> Connect to project).
BLOB_READ_WRITE_TOKEN=

# Generate with: openssl rand -base64 48
# Must be at least 32 characters. Keep secret, never commit.
JWT_SECRET=

# Generate with: npm run hash-password -- "your-chosen-password"
# Paste the printed hash here (starts with $2a$ or $2b$).
ADMIN_PASSWORD_HASH=

# The exact origin (scheme + host, no trailing slash) of the deployed
# admin-panel app, e.g. https://galych-agro-admin.vercel.app
# Only this origin will be allowed to call the /api/admin/* endpoints.
ADMIN_ORIGIN=

# Optional: the admin panel URL shown as a small footer link on the public
# site. Leave empty to hide the link entirely.
NEXT_PUBLIC_ADMIN_URL=
